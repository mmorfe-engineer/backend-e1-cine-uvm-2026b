<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="header">
    <h1>🚪 <%= title %></h1>
    <p>Sistema de Gestión de Cine - UVM Backend 2026B</p>
  </div>

  <div class="nav">
    <a href="/">🏠 Inicio</a>
    <a href="/rooms/view">📋 Lista de Salas</a>
  </div>

  <div class="container">
    <div class="section">
      <h2>✏️ Editar Sala: <%= room.name %></h2>
      
      <div class="card">
        <form action="/rooms/<%= room.id %>&_method=PUT" method="POST">
          <div class="form-group">
            <label for="name">* Nombre:</label>
            <input type="text" id="name" name="name" required value="<%= room.name %>">
          </div>
          
          <div class="form-group">
            <label for="capacity">* Capacidad:</label>
            <input type="number" id="capacity" name="capacity" required min="1" value="<%= room.capacity %>">
          </div>
          
          <div class="form-group">
            <label for="type">Tipo:</label>
            <select id="type" name="type">
              <option value="Regular" <%= room.type === 'Regular' ? 'selected' : '' %>>Regular</option>
              <option value="IMAX" <%= room.type === 'IMAX' ? 'selected' : '' %>>IMAX</option>
              <option value="3D" <%= room.type === '3D' ? 'selected' : '' %>>3D</option>
              <option value="4DX" <%= room.type === '4DX' ? 'selected' : '' %>>4DX</option>
              <option value="VIP" <%= room.type === 'VIP' ? 'selected' : '' %>>VIP</option>
            </select>
          </div>
          
          <div class="form-group">
            <label for="has_accessibility">Accesibilidad:</label>
            <select id="has_accessibility" name="has_accessibility">
              <option value="0" <%= room.has_accessibility === 0 ? 'selected' : '' %>>❌ No</option>
              <option value="1" <%= room.has_accessibility === 1 ? 'selected' : '' %>>✅ Sí</option>
            </select>
          </div>
          
          <input type="hidden" name="_method" value="PUT">
          
          <div class="form-actions">
            <button type="submit" class="btn btn-primary">💾 Actualizar Sala</button>
            <a href="/rooms/view" class="btn btn-secondary">🚫 Cancelar</a>
          </div>
          
          <p style="margin-top: 15px; color: var(--muted); font-size: 0.85rem;">
            * Campos requeridos | Creado: <%= new Date(room.created_at).toLocaleString() %>
          </p>
        </form>
      </div>
    </div>
  </div>

  <footer>
    <p>Sistema de Gestión de Cine - UVM 2026B</p>
  </footer>
</body>
</html>
